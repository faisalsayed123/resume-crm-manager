</nav>

<!-- MOBILE MENU -->
<div class="mobile-menu" id="mobileMenu">
  <a href="#about" class="mobile-nav-link">About</a>
  <a href="#experience" class="mobile-nav-link">Experience</a>
  <a href="#skills" class="mobile-nav-link">Skills</a>
  <a href="#projects" class="mobile-nav-link">Projects</a>
</div>

<!-- HERO -->
<section class="hero" style="border-top:none; padding:0;">
  <div class="hero-left">
    <div class="hero-eyebrow">CRM Systems Architect & E-Commerce Specialist</div>
    <h1 class="hero-name"><em>Faisal Sayed</em></h1>
    <p class="hero-role">CRM Architecture · Customer Journey Design · Multi-Channel Automation · D2C E-Commerce · AI/ML Integration</p>
    <div class="hero-tags">
      <span class="tag">HubSpot</span>
      <span class="tag">Zoho CRM</span>
      <span class="tag">BIK.AI</span>
